---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- ===== SCROLL PROGRESS BAR ===== -->
  <div
    id="scroll-progress"
    class="fixed top-0 left-0 z-[60] h-[3px] bg-[#C4A456] w-0"
  ></div>

  <!-- ===== NAV ===== -->
  <nav
    class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-sm border-b border-neutral-100 shadow-sm h-16 md:h-20"
  >
    <div
      class="flex justify-between items-center max-w-7xl mx-auto px-4 sm:px-6 md:px-8 h-full"
    >
      <a href="/" class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
        <img
          src="/logo-bg.png"
          alt="Good Flight Logo"
          class="h-9 sm:h-11 w-auto rounded-sm"
        />
      </a>
      <div class="hidden md:flex items-center gap-5 lg:gap-8">
        <a
          href="#curso"
          class="text-[#D71920] border-b-2 border-[#D71920] pb-0.5 font-medium text-sm nav-serif"
          >El Curso</a
        >
        <a
          href="#materias"
          class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200 nav-serif"
          >Materias</a
        >
        <a
          href="#nosotros"
          class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200 nav-serif"
          >Nosotros</a
        >
        <a
          href="#requisitos"
          class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200 nav-serif"
          >Requisitos</a
        >
        <a
          href="https://wa.me/5492615391110"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-1.5 text-neutral-500 hover:text-[#D71920] transition-colors text-sm nav-serif whitespace-nowrap"
        >
          <span class="material-symbols-outlined" style="font-size:16px;">phone</span>
          +54 9 261 539-1110
        </a>
      </div>
      <div class="flex items-center gap-2 sm:gap-3">
        <a
          href="https://wa.me/5492615391110?text=Hola%2C+quiero+inscribirme+al+curso+TCP"
          target="_blank"
          rel="noopener"
          class="hidden md:inline-flex bg-[#D71920] text-white px-4 lg:px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-[#ae0011] active:scale-95 transition-all duration-200 shadow-sm whitespace-nowrap"
        >
          Inscribirme
        </a>
        <button
          id="menu-toggle"
          aria-label="Abrir menú"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-lg hover:bg-neutral-100 transition-colors flex-shrink-0"
        >
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="md:hidden absolute top-16 left-0 right-0 bg-white border-b border-neutral-100 shadow-lg px-4 sm:px-6 py-5 flex-col gap-3 hidden max-h-[calc(100vh-4rem)] overflow-y-auto"
    >
      <a href="#curso" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between nav-serif">
        El Curso <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="#materias" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between nav-serif">
        Materias <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="#nosotros" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between nav-serif">
        Nosotros <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="#requisitos" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between nav-serif">
        Requisitos <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a
        href="https://wa.me/5492615391110?text=Hola%2C+quiero+inscribirme+al+curso+TCP"
        target="_blank"
        rel="noopener"
        class="mt-2 w-full bg-[#D71920] text-white py-3.5 rounded-lg font-bold text-sm text-center tracking-wider hover:bg-[#ae0011] transition-colors"
      >
        INSCRIBIRME AL CURSO
      </a>
      <div class="flex gap-3">
        <a
          href="https://wa.me/5492615391110"
          target="_blank"
          rel="noopener"
          class="flex-1 border-2 border-[#C4A456] text-[#C4A456] py-3 rounded-lg font-bold text-xs text-center tracking-wider flex items-center justify-center gap-1.5"
        >
          <span class="material-symbols-outlined" style="font-size:16px;">phone</span>
          WhatsApp
        </a>
        <a
          href="https://instagram.com/ciacgoodflight"
          target="_blank"
          rel="noopener"
          class="flex-1 border-2 border-neutral-200 text-neutral-500 py-3 rounded-lg font-bold text-xs text-center tracking-wider flex items-center justify-center gap-1.5"
        >
          <span class="material-symbols-outlined" style="font-size:16px;">photo_camera</span>
          Instagram
        </a>
      </div>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Montserrat:wght@400;500;600;700;800;900&display=swap");
    .hero-badge { font-family: "Montserrat", sans-serif; letter-spacing: 0.18em; }
    .hero-title { font-family: "Cormorant Garamond", serif; font-weight: 300; line-height: 1.05; letter-spacing: -0.01em; }
    .hero-title em { font-style: italic; font-weight: 700; color: #c4a456; }
    .hero-divider { width: 48px; height: 2px; background: linear-gradient(90deg, #c4a456, transparent); }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(28px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up { animation: fadeInUp 0.8s ease forwards; }
    .animate-fade-in-up-delay-1 { opacity: 0; animation: fadeInUp 0.8s 0.15s ease forwards; }
    .animate-fade-in-up-delay-2 { opacity: 0; animation: fadeInUp 0.8s 0.35s ease forwards; }
    .animate-fade-in-up-delay-3 { opacity: 0; animation: fadeInUp 0.8s 0.55s ease forwards; }
  </style>

  <section class="relative min-h-screen flex items-center pt-16 md:pt-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <video autoplay muted loop playsinline class="w-full h-full object-cover">
        <source src="/avion.mp4" type="video/mp4" />
        <img src="/foto-2.jpeg" alt="Good Flight – Curso TCP" class="w-full h-full object-cover" />
      </video>
      <div class="absolute inset-0 bg-black/60"></div>
      <div class="absolute inset-0 bg-gradient-to-b md:bg-gradient-to-r from-black/70 via-black/40 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 md:px-8 w-full py-10 sm:py-16">
      <div class="flex flex-col md:grid md:grid-cols-2 gap-8 md:gap-12 items-center">

        <!-- Copy -->
        <div class="text-white w-full">
          <div class="animate-fade-in-up">
            <span class="hero-badge inline-block bg-[#C4A456]/15 border border-[#C4A456]/60 text-[#C4A456] px-3 sm:px-4 py-1.5 rounded-full text-[9px] sm:text-[10px] font-700 tracking-widest mb-6 sm:mb-8 uppercase backdrop-blur-sm">
              Próximamente · Cupos Limitados
            </span>
          </div>
          <div class="animate-fade-in-up-delay-1">
            <p
              class="mb-3 sm:mb-4 text-neutral-300"
              style="font-family:'Cormorant Garamond',serif;font-size:clamp(1rem,3vw,1.5rem);font-weight:300;font-style:italic;line-height:1.4;"
            >
              "Nunca es muy tarde para ser<br />quien tú quieras ser."
            </p>
            <h1 class="hero-title text-white mb-5 sm:mb-6" style="font-size: clamp(2.6rem, 10vw, 6rem);">
              Convertite<br />en <em>TCP</em>
            </h1>
            <div class="hero-divider mb-5 sm:mb-7"></div>
          </div>
        </div>

        <!-- Form card -->
        <div class="glass-panel p-5 sm:p-7 md:p-8 rounded-2xl shadow-2xl w-full md:max-w-md md:ml-auto animate-fade-in-up-delay-3">
          <h3
            class="text-neutral-900 mb-1.5"
            style="font-family:'Cormorant Garamond',serif;font-size:clamp(1.3rem,4vw,1.6rem);font-weight:600;"
          >
            Anotate al curso
          </h3>
          <p
            class="text-neutral-500 mb-5 sm:mb-6 text-xs sm:text-sm leading-relaxed"
            style="font-family:'Montserrat',sans-serif;"
          >
            Dejanos tus datos y te contactamos por WhatsApp con toda la información y la fecha de inicio.
          </p>
          <div class="flex items-center gap-3 mb-4 sm:mb-5">
            <div class="flex-1 h-px bg-neutral-200"></div>
            <span class="text-xs text-neutral-400 font-medium whitespace-nowrap" style="font-family:'Montserrat',sans-serif;">dejá tus datos</span>
            <div class="flex-1 h-px bg-neutral-200"></div>
          </div>
          <form class="space-y-3" id="lead-form">
            <div>
              <label class="block text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1.5" style="font-family:'Montserrat',sans-serif;">Nombre Completo</label>
              <input
                type="text"
                name="nombre"
                placeholder="Ej. Ana García"
                class="w-full px-3 sm:px-4 py-2.5 sm:py-3 rounded-lg border border-neutral-300 bg-white text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#C4A456] focus:border-transparent text-sm"
                style="font-family:'Montserrat',sans-serif;"
              />
            </div>
            <div>
              <label class="block text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1.5" style="font-family:'Montserrat',sans-serif;">Teléfono / WhatsApp</label>
              <input
                type="tel"
                name="telefono"
                placeholder="+54 9 261 000-0000"
                class="w-full px-3 sm:px-4 py-2.5 sm:py-3 rounded-lg border border-neutral-300 bg-white text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#C4A456] focus:border-transparent text-sm"
                style="font-family:'Montserrat',sans-serif;"
              />
            </div>
            <div>
              <label class="block text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1.5" style="font-family:'Montserrat',sans-serif;">Ciudad</label>
              <input
                type="text"
                name="ciudad"
                placeholder="Mendoza"
                class="w-full px-3 sm:px-4 py-2.5 sm:py-3 rounded-lg border border-neutral-300 bg-white text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#C4A456] focus:border-transparent text-sm"
                style="font-family:'Montserrat',sans-serif;"
              />
            </div>
            <button
              type="submit"
              class="w-full bg-[#D71920] text-white py-3 sm:py-3.5 rounded-lg font-bold text-xs sm:text-sm tracking-widest hover:bg-[#ae0011] active:scale-[0.98] transition-all duration-200 shadow-lg hover:shadow-xl mt-1"
              style="font-family:'Montserrat',sans-serif;letter-spacing:.14em;"
            >
              RECIBIR INFORMACIÓN
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== INFO RÁPIDA ===== -->
  <section class="bg-[#D71920] py-4 sm:py-5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
      <div class="flex flex-wrap justify-center items-center gap-x-6 gap-y-3 md:gap-x-10 text-white text-xs sm:text-sm font-medium">
        <span class="flex items-center gap-1.5 sm:gap-2">
          <span class="material-symbols-outlined text-[#C4A456] flex-shrink-0" style="font-size:16px;font-variation-settings:'FILL' 1;">schedule</span>
          <span style="font-family:'Montserrat',sans-serif;">Sábados: Mañana y tarde</span>
        </span>
        <span class="text-white/30 hidden md:block">|</span>
        <span class="flex items-center gap-1.5 sm:gap-2">
          <span class="material-symbols-outlined text-[#C4A456] flex-shrink-0" style="font-size:16px;font-variation-settings:'FILL' 1;">calendar_month</span>
          <span style="font-family:'Montserrat',sans-serif;">Estándar o intensivo</span>
        </span>
        <span class="text-white/30 hidden md:block">|</span>
        <span class="flex items-center gap-1.5 sm:gap-2">
          <span class="material-symbols-outlined text-[#C4A456] flex-shrink-0" style="font-size:16px;font-variation-settings:'FILL' 1;">group</span>
          <span style="font-family:'Montserrat',sans-serif;">Cupos limitados</span>
        </span>
      </div>
    </div>
  </section>

  <!-- ===== EL CURSO ===== -->
  <section id="curso" class="py-16 sm:py-24 bg-[#f3f4f5]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
      <div class="text-center">
        <span
          class="text-xs font-bold tracking-widest text-[#C4A456] uppercase mb-3 block"
          style="font-family:'Montserrat',sans-serif;">Formación Integral</span
        >
        <h2
          class="text-[#D71920] mb-4"
          style="font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,5vw,3rem);font-weight:600;"
        >
          Convertite en TCP
        </h2>
        <p
          class="text-neutral-500 max-w-xl mx-auto text-xs sm:text-sm leading-relaxed"
          style="font-family:'Montserrat',sans-serif;"
        >
          Una formación integral que combina teoría y prácticas reales para que estés listo el día que subas a bordo.
        </p>
        <div class="h-0.5 w-20 bg-[#C4A456] mx-auto mt-6"></div>

        <!-- PILLS INFO -->
        <div class="flex flex-wrap justify-center gap-2 sm:gap-3 mt-8">
          <span
            class="flex items-center gap-2 bg-white border border-neutral-200 rounded-full px-3 sm:px-4 py-2 text-xs font-semibold text-neutral-700 shadow-sm"
            style="font-family:'Montserrat',sans-serif;"
          >
            <span class="material-symbols-outlined text-[#C4A456]" style="font-size:15px;font-variation-settings:'FILL' 1;">verified</span>
            Título oficial ANAC
          </span>
          <span
            class="flex items-center gap-2 bg-white border border-neutral-200 rounded-full px-3 sm:px-4 py-2 text-xs font-semibold text-neutral-700 shadow-sm"
            style="font-family:'Montserrat',sans-serif;"
          >
            <span class="material-symbols-outlined text-[#C4A456]" style="font-size:15px;font-variation-settings:'FILL' 1;">location_on</span>
            Mendoza
          </span>
          <span
            class="flex items-center gap-2 bg-white border border-neutral-200 rounded-full px-3 sm:px-4 py-2 text-xs font-semibold text-neutral-700 shadow-sm"
            style="font-family:'Montserrat',sans-serif;"
          >
            <span class="material-symbols-outlined text-[#C4A456]" style="font-size:15px;font-variation-settings:'FILL' 1;">group</span>
            Solo 12 cupos por grupo
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== POR QUÉ GOOD FLIGHT ===== -->
  <section class="py-16 sm:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 md:px-8 text-center">
      <div class="reveal-card opacity-0" style="transition-delay:0.15s;">
        <h2
          class="text-neutral-900 mb-4"
          style="font-family:'Noto Serif',serif;font-size:clamp(1.5rem,4vw,2rem);"
        >
          ¿Por qué elegir Good Flight?
        </h2>
        <p
          class="text-neutral-400 mb-10 leading-relaxed mx-auto"
          style="font-family:'Cormorant Garamond',serif;font-size:clamp(1rem,2.5vw,1.2rem);font-style:italic;"
        >
          Porque todo empieza con alguien que cree en vos. Queremos ser el punto de partida de historias que algún día despeguen muy alto.
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5 text-left">
          <li class="flex items-center gap-3 sm:gap-4 bg-[#f3f4f5] p-4 rounded-xl">
            <div class="bg-red-50 p-2 sm:p-2.5 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-[#D71920]" style="font-size:20px;font-variation-settings:'FILL' 1;">school</span>
            </div>
            <span class="font-bold text-neutral-900 text-sm sm:text-base" style="font-family:'Montserrat',sans-serif;">Instructores idóneos</span>
          </li>
          <li class="flex items-center gap-3 sm:gap-4 bg-[#f3f4f5] p-4 rounded-xl">
            <div class="bg-red-50 p-2 sm:p-2.5 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-[#D71920]" style="font-size:20px;font-variation-settings:'FILL' 1;">menu_book</span>
            </div>
            <span class="font-bold text-neutral-900 text-sm sm:text-base" style="font-family:'Montserrat',sans-serif;">Teoría</span>
          </li>
          <li class="flex items-center gap-3 sm:gap-4 bg-[#f3f4f5] p-4 rounded-xl">
            <div class="bg-red-50 p-2 sm:p-2.5 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-[#D71920]" style="font-size:20px;font-variation-settings:'FILL' 1;">flight_takeoff</span>
            </div>
            <span class="font-bold text-neutral-900 text-sm sm:text-base" style="font-family:'Montserrat',sans-serif;">Prácticas reales</span>
          </li>
          <li class="flex items-center gap-3 sm:gap-4 bg-[#f3f4f5] p-4 rounded-xl">
            <div class="bg-red-50 p-2 sm:p-2.5 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-[#D71920]" style="font-size:20px;font-variation-settings:'FILL' 1;">groups</span>
            </div>
            <span class="font-bold text-neutral-900 text-sm sm:text-base" style="font-family:'Montserrat',sans-serif;">Grupos personalizados</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== MATERIAS ===== -->
  <section id="materias" class="py-16 sm:py-24 bg-neutral-900 text-white overflow-hidden relative">
    <div class="skew-bg"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 relative z-10">
      <div class="mb-10 sm:mb-14 reveal-card opacity-0">
        <span class="text-xs font-bold tracking-widest text-[#C4A456] uppercase mb-3 block">Profesionalismo desde el primer día</span>
        <h2
          class="text-white mb-4"
          style="font-family:'Noto Serif',serif;font-size:clamp(1.5rem,4vw,2rem);"
        >
          Cronograma
        </h2>
        <p class="text-neutral-400 max-w-xl text-xs sm:text-sm leading-relaxed">
          Un plan de estudios completo diseñado para que domines cada aspecto del rol de Tripulante de Cabina de Pasajeros.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">
        {
          [
            { icon: "flight", materia: "Conocimientos Aeronáuticos" },
            { icon: "gavel", materia: "Obligaciones y Responsabilidades" },
            { icon: "psychology", materia: "Factores Humanos" },
            { icon: "emergency", materia: "Procedimientos de Emergencia" },
            { icon: "medical_services", materia: "Información Aeromédica y Primeros Auxilios" },
            { icon: "search", materia: "Búsqueda y Salvamento" },
            { icon: "forest", materia: "Supervivencia" },
            { icon: "inventory_2", materia: "Mercancías Peligrosas" },
            { icon: "language", materia: "Inglés Aeronáutico" },
          ].map((item, i) => (
            <div
              class="reveal-card bg-neutral-800 p-5 sm:p-6 rounded-xl border border-neutral-700 hover:border-[#C4A456]/50 transition-all duration-300 opacity-0"
              style={`transition-delay:${i * 0.07}s`}
            >
              <span
                class="material-symbols-outlined text-[#C4A456] mb-3 block"
                style="font-size:26px;font-variation-settings:'FILL' 1;"
              >
                {item.icon}
              </span>
              <h4
                class="font-bold text-white text-xs sm:text-sm text-center"
                style="font-family:'Noto Serif',serif;"
              >
                {item.materia}
              </h4>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== QUIÉNES SOMOS ===== -->
  <section id="nosotros" class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8">
      <div class="text-center mb-10 sm:mb-16">
        <span class="text-xs font-bold tracking-widest text-[#C4A456] uppercase mb-3 block">Quiénes Somos</span>
        <h2
          class="text-neutral-900 mb-4"
          style="font-family:'Noto Serif',serif;font-size:clamp(1.5rem,4vw,2rem);"
        >
          Una historia de pasión por la aviación
        </h2>
        <div class="h-0.5 w-20 bg-[#C4A456] mx-auto"></div>
      </div>
      <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16 max-w-5xl mx-auto reveal-card opacity-0">
        <div class="w-full md:w-2/5 flex-shrink-0">
          <div class="relative max-w-xs sm:max-w-sm mx-auto md:max-w-none">
            <div class="relative rounded-2xl overflow-hidden shadow-2xl">
              <img
                src="/yo.jpg"
                alt="Débora D. Cerda – Fundadora Good Flight"
                class="w-full h-72 sm:h-96 object-cover object-top"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#C4A456]"></div>
              <div class="absolute bottom-5 left-5 right-5">
                <p class="text-white font-bold text-base sm:text-lg" style="font-family:'Noto Serif',serif;">Débora D. Cerda</p>
                <p class="text-[#C4A456] text-[10px] sm:text-xs font-semibold tracking-widest uppercase">Fundadora & Gerente Responsable</p>
              </div>
            </div>
            <div class="absolute -right-3 top-6 bottom-6 w-0.5 bg-[#C4A456] opacity-40 hidden md:block"></div>
          </div>
        </div>
