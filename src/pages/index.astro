---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ===== SCROLL PROGRESS BAR ===== -->
  <div id="scroll-progress" class="fixed top-0 left-0 z-[60] h-[3px] bg-[#C4A456] w-0"></div>

  <!-- ===== NAV ===== -->
  <nav class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-sm border-b border-neutral-100 shadow-sm h-20">
    <div class="flex justify-between items-center max-w-7xl mx-auto px-6 md:px-8 h-full">

      <a href="/" class="flex items-center gap-3">
        <img src="/logo-bg.png" alt="Good Flight Logo" class="h-11 w-auto rounded-sm" />
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#metodologia" class="text-[#D71920] border-b-2 border-[#D71920] pb-0.5 font-medium text-sm" style="font-family: 'Noto Serif', serif;">Metodología</a>
        <a href="#programa" class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200" style="font-family: 'Noto Serif', serif;">Programa</a>
        <a href="#beneficios" class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200" style="font-family: 'Noto Serif', serif;">Beneficios</a>
        <a href="#preguntas" class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200" style="font-family: 'Noto Serif', serif;">Preguntas</a>
        <a href="https://wa.me/5492615391110" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-neutral-500 hover:text-[#D71920] transition-colors text-sm" style="font-family: 'Noto Serif', serif;">
          <span class="material-symbols-outlined" style="font-size:16px;">phone</span>
          +54 9 261 539-1110
        </a>
      </div>

      <div class="flex items-center gap-3">
        <a href="https://wa.me/5492615391110?text=Hola%2C+quiero+inscribirme+al+curso+TCP" target="_blank" rel="noopener"
          class="hidden md:inline-flex bg-[#D71920] text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-[#ae0011] active:scale-95 transition-all duration-200 shadow-sm">
          Inscribirme
        </a>
        <!-- Hamburger -->
        <button id="menu-toggle" aria-label="Abrir menú"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-lg hover:bg-neutral-100 transition-colors">
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </div>

    <!-- Mobile menu dropdown -->
    <div id="mobile-menu"
      class="md:hidden absolute top-20 left-0 right-0 bg-white border-b border-neutral-100 shadow-lg px-6 py-6 flex-col gap-4 hidden">
      <a href="#metodologia" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between" style="font-family:'Noto Serif',serif;">
        Metodología <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="#programa" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between" style="font-family:'Noto Serif',serif;">
        Programa <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="#beneficios" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between" style="font-family:'Noto Serif',serif;">
