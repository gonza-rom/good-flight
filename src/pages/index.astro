      </a>
      <a href="#preguntas" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between" style="font-family:'Noto Serif',serif;">
        Preguntas <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="https://wa.me/5492615391110?text=Hola%2C+quiero+inscribirme+al+curso+TCP"
