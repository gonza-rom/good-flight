---
import Layout from '../layouts/Layout.astro';
---

<Layout>

  <!-- ===== SCROLL PROGRESS BAR ===== -->
  <div id="scroll-progress" class="fixed top-0 left-0 z-[60] h-[3px] bg-[#C4A456] w-0"></div>

  <!-- ===== NAV ===== -->
  <nav class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-sm border-b border-neutral-100 shadow-sm h-20">
    <div class="flex justify-between items-center max-w-7xl mx-auto px-6 md:px-8 h-full">
      <a href="/" class="flex items-center gap-3">
        <img src="/logo-bg.png" alt="Good Flight Logo" class="h-11 w-auto rounded-sm" />
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#curso" class="text-[#D71920] border-b-2 border-[#D71920] pb-0.5 font-medium text-sm nav-serif">El Curso</a>
        <a href="#materias" class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200 nav-serif">Materias</a>
        <a href="#nosotros" class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200 nav-serif">Nosotros</a>
        <a href="#requisitos" class="text-neutral-600 font-medium text-sm hover:text-[#D71920] transition-colors duration-200 nav-serif">Requisitos</a>
        <a href="https://wa.me/5492615391110" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-neutral-500 hover:text-[#D71920] transition-colors text-sm nav-serif">
          <span class="material-symbols-outlined" style="font-size:16px;">phone</span>
          +54 9 261 539-1110
        </a>
      </div>

      <div class="flex items-center gap-3">
        <a href="https://wa.me/5492615391110?text=Hola%2C+quiero+inscribirme+al+curso+TCP" target="_blank" rel="noopener"
          class="hidden md:inline-flex bg-[#D71920] text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-[#ae0011] active:scale-95 transition-all duration-200 shadow-sm">
          Inscribirme
        </a>
        <button id="menu-toggle" aria-label="Abrir menú"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-lg hover:bg-neutral-100 transition-colors">
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
          <span class="ham-line block w-6 h-0.5 bg-neutral-700 transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu"
      class="md:hidden absolute top-20 left-0 right-0 bg-white border-b border-neutral-100 shadow-lg px-6 py-6 flex-col gap-4 hidden">
      <a href="#curso" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between nav-serif">
        El Curso <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="#materias" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between nav-serif">
        Materias <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="#nosotros" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between nav-serif">
        Nosotros <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="#requisitos" class="mobile-link text-neutral-700 font-medium py-2.5 border-b border-neutral-100 flex items-center justify-between nav-serif">
        Requisitos <span class="material-symbols-outlined text-neutral-400" style="font-size:18px;">chevron_right</span>
      </a>
      <a href="https://wa.me/5492615391110?text=Hola%2C+quiero+inscribirme+al+curso+TCP" target="_blank" rel="noopener"
        class="mt-2 w-full bg-[#D71920] text-white py-3.5 rounded-lg font-bold text-sm text-center tracking-wider hover:bg-[#ae0011] transition-colors">
        INSCRIBIRME AL CURSO
      </a>
      <div class="flex gap-3">
        <a href="https://wa.me/5492615391110" target="_blank" rel="noopener"
          class="flex-1 border-2 border-[#C4A456] text-[#C4A456] py-3 rounded-lg font-bold text-xs text-center tracking-wider flex items-center justify-center gap-1.5">
          <span class="material-symbols-outlined" style="font-size:16px;">phone</span>
          WhatsApp
        </a>
        <a href="https://instagram.com/ciacgoodflight" target="_blank" rel="noopener"
          class="flex-1 border-2 border-neutral-200 text-neutral-500 py-3 rounded-lg font-bold text-xs text-center tracking-wider flex items-center justify-center gap-1.5">
          <span class="material-symbols-outlined" style="font-size:16px;">photo_camera</span>
          Instagram
        </a>
      </div>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <section class="relative min-h-screen flex items-center pt-20 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <video autoplay muted loop playsinline class="w-full h-full object-cover">
        <source src="/avion.mp4" type="video/mp4" />
        <img src="/foto-2.jpeg" alt="Good Flight – Curso TCP" class="w-full h-full object-cover" />
      </video>
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black/55 via-black/20 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8 grid md:grid-cols-2 gap-12 items-center py-16">

      <!-- Copy -->
      <div class="text-white animate-fade-in-up">
        <span class="inline-block bg-[#C4A456] text-white px-4 py-1 rounded-full text-xs font-semibold tracking-widest mb-6 uppercase">
          Próximamente — Cupos Limitados
        </span>
        <h1 class="text-display mb-5 leading-tight" style="font-family:'Noto Serif',serif;">
          Nunca es muy tarde para ser quien tú quieras ser.
        </h1>
        <p class="text-lg font-medium mb-3 text-neutral-100 leading-relaxed">
          Curso de Tripulante de Cabina de Pasajeros (TCP)
        </p>
        <p class="text-sm text-neutral-300 mb-2">
          Modalidad presencial · Mendoza · Sábados de 8 a 12 y 16 a 20
        </p>
        <p class="text-sm text-neutral-400 mb-10">
          Mock Up en CEEPA – El Palomar · Ditching en Círculo de Oficiales – Mendoza
        </p>
        <div class="flex flex-wrap items-center gap-5 text-sm text-neutral-200">
          <span class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#C4A456]" style="font-size:20px;font-variation-settings:'FILL' 1;">verified</span>
            Título Oficial ANAC
          </span>
          <span class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#C4A456]" style="font-size:20px;font-variation-settings:'FILL' 1;">location_on</span>
            Mendoza
          </span>
          <span class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#C4A456]" style="font-size:20px;font-variation-settings:'FILL' 1;">group</span>
            Solo 12 cupos por grupo
          </span>
        </div>
      </div>

      <!-- Form card -->
      <div class="glass-panel p-7 md:p-8 rounded-2xl shadow-2xl w-full md:max-w-md md:ml-auto animate-fade-in-up-delay-2">
        <h3 class="text-headline-md text-neutral-900 mb-1.5" style="font-family:'Noto Serif',serif;">Anotate al curso</h3>
        <p class="text-neutral-500 mb-6 text-sm leading-relaxed">
          Dejanos tus datos y te contactamos por WhatsApp con toda la información y la fecha de inicio.
        </p>

        <a
          href="https://wa.me/5492615391110?text=Hola%2C+quiero+m%C3%A1s+informaci%C3%B3n+sobre+el+curso+de+TCP"
          target="_blank" rel="noopener"
          class="w-full flex items-center justify-center gap-3 bg-[#25D366] text-white py-4 rounded-xl font-bold text-sm tracking-wider hover:bg-[#1ebe5d] active:scale-[0.98] transition-all duration-200 shadow-lg hover:shadow-xl mb-5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          QUIERO INSCRIBIRME
        </a>

        <div class="flex items-center gap-3 mb-5">
          <div class="flex-1 h-px bg-neutral-200"></div>
          <span class="text-xs text-neutral-400 font-medium">o dejá tus datos</span>
          <div class="flex-1 h-px bg-neutral-200"></div>
        </div>

        <form class="space-y-3" id="lead-form">
          <div>
            <label class="block text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1.5">Nombre Completo</label>
            <input type="text" name="nombre" placeholder="Ej. Ana García"
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#C4A456] focus:border-transparent text-sm" />
          </div>
          <div>
            <label class="block text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1.5">Teléfono / WhatsApp</label>
            <input type="tel" name="telefono" placeholder="+54 9 261 000-0000"
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#C4A456] focus:border-transparent text-sm" />
          </div>
          <div>
            <label class="block text-xs font-bold text-neutral-500 uppercase tracking-wider mb-1.5">Ciudad</label>
            <input type="text" name="ciudad" placeholder="Mendoza"
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 bg-white text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-[#C4A456] focus:border-transparent text-sm" />
          </div>
          <button type="submit"
            class="w-full bg-[#D71920] text-white py-3.5 rounded-lg font-bold text-sm tracking-widest hover:bg-[#ae0011] active:scale-[0.98] transition-all duration-200 shadow-lg hover:shadow-xl mt-1">
            RECIBIR INFORMACIÓN
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- ===== INFO RÁPIDA ===== -->
  <section class="bg-[#D71920] py-5">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-3 text-white text-sm font-medium">
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[#C4A456]" style="font-size:18px;font-variation-settings:'FILL' 1;">schedule</span>
          Sábados 8–12 y 16–20
        </span>
        <span class="text-white/30 hidden md:block">|</span>
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[#C4A456]" style="font-size:18px;font-variation-settings:'FILL' 1;">calendar_month</span>
          Duración: 6 / 8 / 12 meses
        </span>
        <span class="text-white/30 hidden md:block">|</span>
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[#C4A456]" style="font-size:18px;font-variation-settings:'FILL' 1;">group</span>
          Máximo 12 personas por grupo
        </span>
        <span class="text-white/30 hidden md:block">|</span>
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[#C4A456]" style="font-size:18px;font-variation-settings:'FILL' 1;">location_on</span>
          Mendoza · Presencial
        </span>
      </div>
    </div>
  </section>

  <!-- ===== EL CURSO ===== -->
  <section id="curso" class="py-24 bg-[#f3f4f5]">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="text-center mb-16">
        <span class="text-xs font-bold tracking-widest text-[#C4A456] uppercase mb-3 block">Formación Integral</span>
        <h2 class="text-headline-lg text-[#D71920] mb-4" style="font-family:'Noto Serif',serif;">Convertite en TCP</h2>
        <p class="text-neutral-500 max-w-xl mx-auto text-sm leading-relaxed">
          Una formación integral que combina teoría y prácticas reales para que estés listo el día que subas a bordo.
        </p>
        <div class="h-0.5 w-20 bg-[#C4A456] mx-auto mt-6"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="reveal-card bg-white p-8 rounded-xl shadow-sm border-b-2 border-[#C4A456] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 opacity-0">
          <div class="flex items-start justify-between mb-6">
            <span class="material-symbols-outlined text-5xl text-[#C4A456]" style="font-variation-settings:'FILL' 1;">location_city</span>
            <span class="text-6xl font-black text-neutral-100 leading-none select-none" style="font-family:'Noto Serif',serif;">01</span>
          </div>
          <h4 class="font-bold text-neutral-900 text-lg mb-3" style="font-family:'Noto Serif',serif;">Formación Presencial</h4>
          <p class="text-neutral-500 text-sm leading-relaxed">Clases los sábados en Mendoza. Mock Up en CEEPA – El Palomar y Ditching en el Círculo de Oficiales de Mendoza.</p>
        </div>

        <!-- Card 2 -->
        <div class="reveal-card bg-white p-8 rounded-xl shadow-sm border-b-2 border-[#C4A456] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 opacity-0" style="transition-delay:0.12s;">
          <div class="flex items-start justify-between mb-6">
            <span class="material-symbols-outlined text-5xl text-[#C4A456]" style="font-variation-settings:'FILL' 1;">workspace_premium</span>
            <span class="text-6xl font-black text-neutral-100 leading-none select-none" style="font-family:'Noto Serif',serif;">02</span>
          </div>
          <h4 class="font-bold text-neutral-900 text-lg mb-3" style="font-family:'Noto Serif',serif;">Aval ANAC</h4>
          <p class="text-neutral-500 text-sm leading-relaxed">Programa avalado por la Administración Nacional de Aviación Civil. Título oficial reconocido por todas las aerolíneas.</p>
        </div>

        <!-- Card 3 -->
        <div class="reveal-card bg-white p-8 rounded-xl shadow-sm border-b-2 border-[#C4A456] hover:shadow-xl hover:-translate-y-1 transition-all duration-300 opacity-0" style="transition-delay:0.24s;">
          <div class="flex items-start justify-between mb-6">
            <span class="material-symbols-outlined text-5xl text-[#C4A456]" style="font-variation-settings:'FILL' 1;">menu_book</span>
            <span class="text-6xl font-black text-neutral-100 leading-none select-none" style="font-family:'Noto Serif',serif;">03</span>
          </div>
          <h4 class="font-bold text-neutral-900 text-lg mb-3" style="font-family:'Noto Serif',serif;">Currícula Profesional</h4>
          <p class="text-neutral-500 text-sm leading-relaxed">Desde seguridad aérea y primeros auxilios hasta inglés aeronáutico y mercancías peligrosas. Todo lo que necesitás para volar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FOTOS DEL CURSO ===== -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8 flex flex-col md:flex-row items-center gap-16">

      <!-- Bloque de fotos -->
      <div class="md:w-1/2 reveal-card opacity-0">
        <div class="relative">
          <!-- Foto principal -->
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img src="/foto-2.jpeg" alt="Prácticas en aeronave – Good Flight"
              class="w-full h-72 object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#C4A456]"></div>
          </div>
          <!-- Foto secundaria -->
          <div class="relative mt-4 ml-12 rounded-2xl overflow-hidden shadow-xl border-4 border-white">
            <img src="/foto-3.jpeg" alt="Prácticas de ditching en pileta – Good Flight"
              class="w-full h-52 object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 h-1 bg-[#C4A456]"></div>
          </div>
          <!-- Línea decorativa -->
          <div class="absolute -left-4 top-8 bottom-8 w-0.5 bg-[#C4A456] opacity-40 rounded-full hidden md:block"></div>
          <!-- Badge -->
          <div class="absolute -bottom-4 left-6 bg-[#D71920] text-white px-5 py-2.5 rounded-full shadow-lg flex items-center gap-2 text-sm font-bold tracking-wide">
            <span class="material-symbols-outlined" style="font-size:16px;font-variation-settings:'FILL' 1;">verified</span>
            Certificado ANAC
          </div>
        </div>
      </div>

      <!-- Texto -->
      <div class="md:w-1/2 reveal-card opacity-0 pt-8" style="transition-delay:0.15s;">
        <h2 class="text-headline-lg text-neutral-900 mb-5" style="font-family:'Noto Serif',serif;">¿Por qué elegir Good Flight?</h2>
        <p class="text-neutral-500 text-lg mb-10 italic leading-relaxed" style="font-family:'Noto Serif',serif;">
          "Liderando la formación aeronáutica con trayectoria y excelencia académica en Mendoza."
        </p>
        <ul class="space-y-7">
          <li class="flex items-start gap-5">
            <div class="bg-red-50 p-2.5 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-[#D71920]" style="font-size:22px;font-variation-settings:'FILL' 1;">check_circle</span>
            </div>
            <div>
              <span class="font-bold text-neutral-900 block mb-1">Instructores Activos</span>
              <span class="text-neutral-500 text-sm leading-relaxed">Aprendé de profesionales que operan actualmente en aerolíneas nacionales e internacionales.</span>
            </div>
          </li>
          <li class="flex items-start gap-5">
            <div class="bg-red-50 p-2.5 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-[#D71920]" style="font-size:22px;font-variation-settings:'FILL' 1;">check_circle</span>
            </div>
            <div>
              <span class="font-bold text-neutral-900 block mb-1">Prácticas Reales</span>
              <span class="text-neutral-500 text-sm leading-relaxed">Mock Up en aeronave real en CEEPA (El Palomar) y prácticas de ditching acuático en Mendoza.</span>
            </div>
          </li>
          <li class="flex items-start gap-5">
            <div class="bg-red-50 p-2.5 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-[#D71920]" style="font-size:22px;font-variation-settings:'FILL' 1;">check_circle</span>
            </div>
            <div>
              <span class="font-bold text-neutral-900 block mb-1">Grupos Reducidos</span>
              <span class="text-neutral-500 text-sm leading-relaxed">Máximo 12 alumnos por grupo para garantizar una atención personalizada y aprendizaje real.</span>
            </div>
          </li>
          <li class="flex items-start gap-5">
            <div class="bg-red-50 p-2.5 rounded-lg flex-shrink-0">
              <span class="material-symbols-outlined text-[#D71920]" style="font-size:22px;font-variation-settings:'FILL' 1;">check_circle</span>
            </div>
            <div>
              <span class="font-bold text-neutral-900 block mb-1">Bolsa de Trabajo</span>
              <span class="text-neutral-500 text-sm leading-relaxed">Convenios exclusivos con aerolíneas nacionales e internacionales para nuestros egresados.</span>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== MATERIAS ===== -->
  <section id="materias" class="py-24 bg-neutral-900 text-white overflow-hidden relative">
    <div class="skew-bg"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-8 relative z-10">
      <div class="mb-14 reveal-card opacity-0">
        <span class="text-xs font-bold tracking-widest text-[#C4A456] uppercase mb-3 block">Profesionalismo desde el primer día</span>
        <h2 class="text-headline-lg text-white mb-4" style="font-family:'Noto Serif',serif;">Materias del Curso TCP</h2>
        <p class="text-neutral-400 max-w-xl text-sm leading-relaxed">
          Un plan de estudios completo diseñado para que domines cada aspecto del rol de Tripulante de Cabina de Pasajeros.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {[
          { icon: 'flight', materia: 'Conocimientos Aeronáuticos', desc: 'Fundamentos de la aviación y operación de aeronaves.' },
          { icon: 'gavel', materia: 'Obligaciones y Responsabilidades', desc: 'Marco legal y reglamentario de la tripulación de cabina.' },
          { icon: 'psychology', materia: 'Factores Humanos', desc: 'Comunicación, trabajo en equipo y toma de decisiones.' },
          { icon: 'emergency', materia: 'Procedimientos de Emergencia', desc: 'Evacuación, incendios, descompresión y más.' },
          { icon: 'medical_services', materia: 'Información Aeromédica y Primeros Auxilios', desc: 'Atención médica a bordo en situaciones críticas.' },
          { icon: 'search', materia: 'Búsqueda y Salvamento', desc: 'Protocolos SAR y coordinación con servicios de rescate.' },
          { icon: 'forest', materia: 'Supervivencia', desc: 'Técnicas de supervivencia en distintos entornos.' },
          { icon: 'inventory_2', materia: 'Mercancías Peligrosas', desc: 'Identificación, clasificación y manejo de materiales peligrosos.' },
